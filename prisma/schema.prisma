// ─── VETTOCHAT DATABASE SCHEMA ──────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. CLIENTS (The Business / Contractor)
model Client {
  id              String   @id @default(uuid())
  supabaseUserId  String?  @unique  // Links to Supabase auth.users.id
  email           String?
  businessName    String
  ownerFullName   String
  ownerPhone      String
  industry        String
  createdAt       DateTime @default(now())

  leads           Lead[]

  onboarding      OnboardingSettings?

  @@map("clients")
}

// 2. LEADS (Captured from the Chatbot)
model Lead {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  intent    String
  urgency   String
  score     Int      @default(0)
  status    String   @default("new")
  createdAt DateTime @default(now())

  companyId String
  client    Client   @relation(fields: [companyId], references: [id])

  @@map("leads")
}

model OnboardingSettings {
  id                  String   @id @default(uuid())
  client_id           String   @unique // @unique enforces the 1-to-1 relationship
  businessName        String?
  botName             String?
  themeColor          String?
  companyWebsite      String?
  onboardingCompleted Boolean  @default(false)
  created_at          DateTime @default(now())

  // The strict relational link back to the parent client
  client              Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  // This maps the Prisma model to the exact Supabase table name we generated in SQL
  @@map("onboarding_settings")
}

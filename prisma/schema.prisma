// ─── VETTOCHAT DATABASE SCHEMA ──────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. CLIENTS — single source of truth for all user data and config
model Client {
  id              String   @id @default(uuid())
  supabaseUserId  String?  @unique
  email           String?
  businessName    String
  ownerFullName   String
  ownerPhone      String
  industry        String
  // Bot / branding config (editable from dashboard)
  botName         String?
  themeColor      String?
  companyWebsite  String?
  smsPhone        String?
  widgetLive      Boolean  @default(true)
  fullConfig      Json?
  createdAt       DateTime @default(now())

  leads           Lead[]
  onboarding      OnboardingSettings?

  @@map("clients")
}

// 2. LEADS (Captured from the Chatbot)
model Lead {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  intent    String
  urgency   String
  location  String?
  budget    String?
  score     Int      @default(0)
  status    String   @default("new")
  createdAt DateTime @default(now())

  companyId String
  client    Client   @relation(fields: [companyId], references: [id])

  @@map("leads")
}

// 2. ONBOARDING — tracks progress only, no editable business data
model OnboardingSettings {
  id                  String    @id @default(uuid())
  client_id           String    @unique
  onboardingCompleted Boolean   @default(false)
  currentStep         Int       @default(1)
  completedAt         DateTime?
  created_at          DateTime  @default(now())

  client              Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("onboarding_settings")
}

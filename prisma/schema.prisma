// ─── VETTOCHAT DATABASE SCHEMA ──────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. CLIENTS (The Business / Contractor)
model Client {
  id            String   @id @default(uuid())
  businessName  String
  ownerFullName String
  ownerPhone    String
  industry      String
  createdAt     DateTime @default(now())

  leads         Lead[]

  @@map("clients")
}

// 2. LEADS (Captured from the Chatbot)
model Lead {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  intent    String
  urgency   String
  score     Int      @default(0)
  status    String   @default("new")
  createdAt DateTime @default(now())

  companyId String
  client    Client   @relation(fields: [companyId], references: [id])

  @@map("leads")
}
